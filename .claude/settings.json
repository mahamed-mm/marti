{
  "permissions": {
    "defaultMode": "plan",
    "disableBypassPermissionsMode": "disable",
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Write",
      "Edit",
      "mcp__xcodebuildmcp__*",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git stash *)",
      "Bash(git restore *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git fetch *)",
      "Bash(swift *)",
      "Bash(swiftlint *)",
      "Bash(swift-format *)",
      "Bash(xcrun simctl *)",
      "Bash(xcodebuild *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(fd *)",
      "Bash(find *)",
      "Bash(wc *)",
      "Bash(diff *)",
      "Bash(tree *)",
      "Bash(pwd)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(touch *)",
      "Bash(chmod *)",
      "Bash(echo *)",
      "Bash(date *)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(git reset *)",
      "Bash(git rebase *)",
      "Bash(git merge *)",
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Edit(docs/PRD.md)",
      "Edit(docs/STATUS.md)",
      "Edit(docs/ARCHITECTURE.md)",
      "Edit(docs/DESIGN.md)",
      "Edit(docs/db/*.sql)",
      "Edit(.claude/jobs/coo/control/decisions.md)",
      "Write(docs/PRD.md)",
      "Write(docs/STATUS.md)",
      "Write(docs/ARCHITECTURE.md)",
      "Write(docs/DESIGN.md)",
      "Write(docs/db/*.sql)",
      "Write(.claude/jobs/coo/control/decisions.md)"
    ],
    "deny": [
      "Read(.env*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/Secrets.swift)",
      "Read(**/GoogleService-Info.plist)",
      "Read(~/.netrc)",
      "Read(**/.netrc)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/*.p12)",
      "Read(**/*.mobileprovision)",
      "Write(.env*)",
      "Write(**/Secrets.swift)",
      "Edit(.env*)",
      "Edit(**/Secrets.swift)",
      "Bash(cat .env*)",
      "Bash(cat **/.netrc)",
      "Bash(cat ~/.netrc)",
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(chown *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(rsync *)",
      "Bash(git push *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fd*)",
      "Bash(git filter-branch *)",
      "Bash(git filter-repo *)",
      "Bash(gh secret *)",
      "Bash(gh variable *)",
      "Bash(gh auth logout *)"
    ]
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "cleanupPeriodDays": 30,
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-swift-edit.sh"
          }
        ]
      }
    ]
  }
}